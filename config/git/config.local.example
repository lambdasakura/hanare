# git の個人設定（config.local にコピーして編集）
# メインの config から [include] path = config.local で読み込まれる

[user]
	email = you@example.com
	name = Your Name

[core]
	pager = less

[alias]
	br = branch
	co = checkout
	st = status
	sh = show
	so = remote show origin
	ft = fetch
	up = pull --rebase
	ad = add
	ci = commit -a
	cam = commit -a --amend
	ba = branch -a
	bm = branch --merged
	bn = branch --no-merged
	wc = whatchanged
	ls = log --stat
	lp = log -p
	la = log --pretty=\"format:%ad %h (%an): %s\" --date=short
	oneline = log --pretty=oneline
	log-graph = log --graph --date=short --pretty=format:'%Cgreen%h %cd %Cblue%cn %Creset%s'
	log-all = log --graph --all --color --pretty='%x09%h %cn%x09%s %Cred%d%Creset'
	dm = diff master
	dw = diff --color-words
	dc = diff --cached
	ds = diff --staged
	d1 = diff HEAD~
	gr = grep
	gn = grep -n

[color]
	status = auto
	diff = auto
	branch = auto
	interactive = auto
	grep = auto

[i18n]
	commitencoding = UTF-8

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[pager]
	branch = false

# ghq を使う場合
# [ghq]
# 	root = /home/you/dev/src

# 組織ごとに異なる設定を使う場合
# [includeIf "gitdir:~/dev/src/github.com/your-org/"]
# 	path = ~/.config/git/config-your-org

# GitLab の認証を glab CLI 経由で行う場合
# [credential "https://gitlab.example.com"]
# 	helper =
# 	helper = !/home/ubuntu/.config/mise/installs/glab/1.89.0/bin/glab auth git-credential
